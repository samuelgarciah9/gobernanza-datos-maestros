# Plantilla de configuracion  -  copia este archivo como  .env  y llena los valores.
# (El archivo .env NO se comparte: contiene credenciales.)

# Carpeta del Oracle Instant Client (modo Thick).
# OPCIONAL: si el paquete incluye la carpeta 'instantclient' junto al proyecto,
# puedes DEJAR ESTA LINEA VACIA o borrarla; connection.py la detecta sola.
# Si tienes el Instant Client instalado en otra ruta, apunta aqui:
ORACLE_CLIENT_LIB_DIR=

# Conexion a Oracle (servidor ERP-PROD)
ORACLE_USER=QAD
ORACLE_PASSWORD=tu_password_aqui
ORACLE_HOST=oracle-host.example
ORACLE_PORT=1521
ORACLE_SID=ORCLPDB1
